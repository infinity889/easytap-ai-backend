DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-backend-domain.com

# Frontend domains (CORS)
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app

# Frontend URLs
FRONTEND_URL=https://your-frontend-domain.vercel.app
FRONTEND_GOOGLE_CALLBACK_URL=https://your-frontend-domain.vercel.app/auth/callback

# Backend public URL
BACKEND_BASE_URL=https://your-backend-domain.com

# Google OAuth (optional but recommended)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-backend-domain.com/api/auth/google/callback/

# AI
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Job providers
HH_API_URL=https://api.hh.ru
REMOTIVE_API_URL=https://remotive.com/api
JOB_SEARCH_TIMEOUT=12
